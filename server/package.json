{
  "name": "server",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply uradori-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply uradori-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.9",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "drizzle-kit": "^0.31.10",
    "wrangler": "^4.4.0"
  }
}